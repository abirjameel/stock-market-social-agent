# Copy to `.env` for local development. In Cloud Run, set these as env vars /
# secrets instead (see deploy/deploy.sh) - `.env` is git-ignored and never
# deployed.

# --- Google Cloud / Gemini ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Set to true to use Vertex AI (recommended on Cloud Run: uses the service
# account's credentials, no API key to manage). Set to false + GEMINI_API_KEY
# to use the Gemini Developer API instead (simpler for local dev).
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_API_KEY=

CONTENT_MODEL=gemini-2.5-flash
IMAGE_MODEL=gemini-2.5-flash-image

# Firestore ALWAYS needs real Google Cloud credentials (there's no API-key
# option), even if you're using GEMINI_API_KEY above instead of Vertex AI for
# Gemini. On Cloud Run this comes for free from the service account. Locally,
# either run `gcloud auth application-default login`, or point this at a
# downloaded service-account JSON key (Cloud Datastore User role is enough):
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firestore-key.json

# --- Market data ---
FINNHUB_API_KEY=
MARKET_WATCHLIST=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,BRK-B,JPM,XOM

# --- Firestore ---
FIRESTORE_COLLECTION_DRAFTS=post_drafts
FIRESTORE_COLLECTION_HISTORY=post_history
DRAFT_EXPIRY_HOURS=12

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Random string you also set when calling Telegram's setWebhook (see
# deploy/telegram_webhook_setup.md). Prevents random internet traffic from
# hitting your webhook and triggering fake approvals.
TELEGRAM_WEBHOOK_SECRET=

# Shared secret Cloud Scheduler must send as the `X-Scheduler-Secret` header.
# Required in production since the Cloud Run service has to be public for the
# Telegram webhook to reach it.
SCHEDULER_SECRET=

# --- Google Cloud Storage (post image archive) ---
# Bucket must already exist with public read access on its objects (see
# docs/ACCESS_SETUP_CHECKLIST.md). Auth uses the same Application Default
# Credentials as Firestore above - no tokens to manage or refresh.
GCS_BUCKET_NAME=
GCS_FOLDER=posts

# --- Instagram (Meta Graph API) ---
# Set to false to fully disable Instagram publishing and its token-refresh
# job (e.g. while waiting on Meta App Review/API access) - when false,
# INSTAGRAM_ACCESS_TOKEN/INSTAGRAM_BUSINESS_ACCOUNT_ID can stay blank.
POST_TO_INSTAGRAM=true
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_GRAPH_API_VERSION=v21.0

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:REPLACE_ME
LINKEDIN_ORGANIZATION_URN=urn:li:organization:REPLACE_ME
LINKEDIN_API_VERSION=202601
POST_TO_LINKEDIN_PERSONAL=true
POST_TO_LINKEDIN_ORGANIZATION=true
# Optional: only needed if LinkedIn has approved refresh-token rotation for
# your app (services/token_refresh.py degrades gracefully without these).
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
